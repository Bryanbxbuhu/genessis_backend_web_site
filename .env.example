# Core API credentials
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini
LLM_PROVIDER=openai

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
DATABASE_SECRET=your_database_secret_here

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# External providers
RAPID_API_KEY=your_rapid_api_key_here
WIKIMEDIA_CLIENT_ID=your_wikimedia_client_id_here
WIKIMEDIA_CLIENT_SECRET=your_wikimedia_client_secret_here
WIKIMEDIA_ACCESS_TOKEN=your_wikimedia_access_token_here

# Optional Ollama/local-runtime settings
OLLAMA_KEY=your_ollama_key_here
OLLAMA_MODEL=deepseek-v3.1
OLLAMA_HOST=https://ollama.com
BLACKBIRD_MAX_CONCURRENCY=30
BLACKBIRD_TIMEOUT_SECONDS=1800
MAX_FINDINGS_FOR_LLM=10
MAX_OUTPUT_TOKENS=1200
OLLAMA_TEMPERATURE=0.2
