#!/usr/bin/env python3
"""
Pre-commit guard: Prevent committing .env.local or .venv to git.

This script checks if any staged files include:
- .env.local (secrets file)
- .venv/ (virtual environment directory)

If found, the commit is aborted with an error message.

Installation:
    ln -s ../../.github/hooks/pre-commit .git/hooks/pre-commit
    chmod +x .git/hooks/pre-commit

Or for Windows:
    copy .github\hooks\pre-commit .git\hooks\pre-commit
"""
import subprocess
import sys

def main():
    """Check staged files for forbidden patterns."""
    try:
        # Get list of staged files
        result = subprocess.run(
            ['git', 'diff', '--cached', '--name-only'],
            capture_output=True,
            text=True,
            check=True
        )
        staged_files = result.stdout.strip().split('\n')
        
        # Forbidden patterns
        forbidden = []
        for file in staged_files:
            if not file:
                continue
            if '.env.local' in file:
                forbidden.append(f"  - {file} (contains secrets)")
            if '.venv/' in file or file == '.venv':
                forbidden.append(f"  - {file} (virtual environment)")
        
        if forbidden:
            print("\n❌ COMMIT BLOCKED: Forbidden files detected!")
            print("\nThe following files should NOT be committed:\n")
            for item in forbidden:
                print(item)
            print("\nTo fix:")
            print("  1. Remove from staging: git reset HEAD <file>")
            print("  2. Ensure .gitignore includes: .env.local and .venv/")
            print("  3. Remove from git index: git rm --cached <file>")
            print("\nIf you need to override (NOT RECOMMENDED):")
            print("  git commit --no-verify\n")
            return 1
        
        return 0
    
    except subprocess.CalledProcessError as e:
        print(f"Error checking staged files: {e}")
        return 1

if __name__ == '__main__':
    sys.exit(main())
